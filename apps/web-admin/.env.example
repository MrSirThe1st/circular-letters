# Next.js admin dashboard environment variables
# Copy to .env.local and fill in your values
# NEXT_PUBLIC_ prefix for client-accessible vars

# Supabase (client-side access)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key-here

# Supabase (server-side only - NEVER expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Database (if direct access needed)
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# File uploads
UPLOAD_MAX_SIZE=10485760
ALLOWED_AUDIO_TYPES=audio/mpeg,audio/mp3,audio/wav
ALLOWED_PDF_TYPES=application/pdf
SUPABASE_AUDIO_BUCKET=sermon-audio
SUPABASE_TTS_AUDIO_BUCKET=sermon-audio

# App config
NEXT_PUBLIC_APP_NAME=Sermon Admin

# ElevenLabs (server-side only)
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here
# Optional: defaults to https://api.elevenlabs.io
ELEVENLABS_BASE_URL=https://api.elevenlabs.io

# Seeded admin accounts (JSON array)
# Example: ADMIN_SEED_USERS=[{"email":"admin@circularletter.org","password":"change-me-now"}]
ADMIN_SEED_USERS=[]
