# Expo mobile app environment variables
# Copy to .env.local and fill in your values
# Expo requires EXPO_PUBLIC_ prefix for client-accessible vars

# Supabase (public client access)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key-here

# API endpoint (admin dashboard or separate API)
EXPO_PUBLIC_API_URL=http://localhost:3000/api

# App config
EXPO_PUBLIC_APP_NAME=Sermon App
